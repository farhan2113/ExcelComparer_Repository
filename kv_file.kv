<Home>:
    md_bg_color:'purple'
    FloatLayout:
        
        MDFillRoundFlatButton:
            text:'load first excel file'
            pos_hint:{'center_x':0.3, 'center_y':0.6}
            font_size:dp(20)
            size_hint:(0.2, 0.1)
            md_bg_color:'orange'
            on_press:root.load_file(self)
            spacing:'5dp'
            id:btn_1
        MDFillRoundFlatButton:
            text:'load second excel file'
            pos_hint:{'center_x':0.6, 'center_y':0.6}
            font_size:dp(20)
            size_hint:(0.2, 0.1)
            md_bg_color:'orange'
            id:btn_2
            on_press:root.load_file(self)

        MDFillRoundFlatButton:
            text:'compare two files'
            pos_hint:{'center_x':0.45, 'center_y':0.4}
            font_size:dp(20)
            size_hint:(0.2, 0.1)
            md_bg_color:'orange'
            on_press:root.compare_files()